{
  "name": "google-ads-baby",
  "description": "Google Ads campaign management MCP server with two-phase safety confirmations. Read campaigns, adjust budgets, pause/enable — every mutation requires explicit user approval.",
  "version": "0.1.0",
  "author": {
    "name": "Jacek Mariański",
    "url": "https://treetank.net"
  },
  "license": "MIT",
  "keywords": ["google-ads", "mcp", "campaigns", "safety"],
  "hooks": "../hooks.json",
  "interface": {
    "displayName": "Google Ads Baby",
    "shortDescription": "Manage Google Ads campaigns through a safe local MCP server.",
    "longDescription": "Google Ads MCP server for listing accounts and campaigns, adjusting budgets, changing campaign status, and preparing new Search campaigns, ad groups, and responsive search ads with two-phase safety confirmation.",
    "developerName": "Jacek Marianski",
    "category": "Productivity",
    "capabilities": ["Interactive", "Write"],
    "defaultPrompt": [
      "Set up Google Ads authentication.",
      "List my Google Ads accounts.",
      "Show campaigns for a selected account."
    ],
    "brandColor": "#2563EB"
  },
  "mcpServers": {
    "google-ads": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/server/dist/index.js"],
      "env": {
        "CLAUDE_PLUGIN_DATA": "${CLAUDE_PLUGIN_DATA:-}",
        "GOOGLE_ADS_DEVELOPER_TOKEN": "${GOOGLE_ADS_DEVELOPER_TOKEN:-}",
        "GOOGLE_ADS_MCC_ID": "${GOOGLE_ADS_MCC_ID:-}",
        "GOOGLE_ADS_REFRESH_TOKEN": "${GOOGLE_ADS_REFRESH_TOKEN:-}",
        "GOOGLE_ADS_CLIENT_ID": "${GOOGLE_ADS_CLIENT_ID:-}",
        "GOOGLE_ADS_CLIENT_SECRET": "${GOOGLE_ADS_CLIENT_SECRET:-}",
        "GOOGLE_ADS_SAFETY_LEVEL": "${GOOGLE_ADS_SAFETY_LEVEL:-}",
        "GOOGLE_ADS_ENABLE_MANUAL_CONFIRM": "${GOOGLE_ADS_ENABLE_MANUAL_CONFIRM:-0}",
        "GOOGLE_ADS_MUTATION_TOKEN_TTL_SECONDS": "${GOOGLE_ADS_MUTATION_TOKEN_TTL_SECONDS:-}",
        "GOOGLE_ADS_CONFIRM_STATE_TTL_SECONDS": "${GOOGLE_ADS_CONFIRM_STATE_TTL_SECONDS:-}"
      }
    }
  }
}
