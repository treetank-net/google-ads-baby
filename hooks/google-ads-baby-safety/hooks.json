{
  "description": "Google Ads Baby safety gate. Blocks confirm_mutation until the user replies with the safe word.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__google[-_]ads__(?:prepare_|confirm_)",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y --package @treetank/google-ads-baby google-ads-baby-safety-hook pre-tool"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y --package @treetank/google-ads-baby google-ads-baby-safety-hook user-submit"
          }
        ]
      }
    ]
  }
}
